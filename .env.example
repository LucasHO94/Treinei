# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase.
# Nunca commitar .env.local (já está no .gitignore).

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Web Push (VAPID) — gerar com: npx web-push generate-vapid-keys
# A chave pública vai no frontend; a privada fica só nos secrets da Edge Function (Fase 4).
VITE_VAPID_PUBLIC_KEY=
